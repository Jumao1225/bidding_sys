# ----------------------------------------------------
# 关系型数据库配置 (PostgreSQL)
# ----------------------------------------------------
# 采用 PostgreSQL 支持企业级并发
DATABASE_URL=postgresql://bidding_user:bidding_password@localhost:5432/bidding_sys

# ----------------------------------------------------
# 缓存与消息中间件配置 (Redis)
# ----------------------------------------------------
# 采用 Redis 支持 Celery 分布式任务队列与 SSE 实时消息推送
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------
# 关系型数据库 (PostgreSQL) 连接池高级配置
# ----------------------------------------------------
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ----------------------------------------------------
# 跨域配置 (本地前端端口)
# ----------------------------------------------------
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# ----------------------------------------------------
# 大模型配置 (请填入您的真实 Key)
# ----------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o
